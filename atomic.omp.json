{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#f38ba8",
          "foreground": "#1e1e2e",
          "leading_diamond": "\u256d\u2500\ue0b6",
          "style": "diamond",
          "template": "<parentBackground>\ue0b0</> \uf292 ",
          "type": "root"
        },
        {
          "background": "#fab387",
          "foreground": "#1e1e2e",
          "leading_diamond": "\u256d\u2500\ue0b6",
          "powerline_symbol": "\ue0b0",
          "options": {
            "folder_separator_icon": " \ue0b1 ",
            "home_icon": "\ue617",
            "mixed_threshold": 6,
            "style": "mixed"
          },
          "style": "powerline",
          "template": " \uf07b {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#f9e2af",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#f2cdcd{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#cba6f7{{ end }}",
            "{{ if gt .Ahead 0 }}#b4befe{{ end }}",
            "{{ if gt .Behind 0 }}#b4befe{{ end }}"
          ],
          "foreground": "#1e1e2e",
          "powerline_symbol": "\ue0b0",
          "options": {
            "branch_icon": "\ue725 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "powerline",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#f38ba8> \uf046 {{ .Staging.String }}</>{{ end }} ",
          "trailing_diamond": "\ue0b0",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "#cba6f7",
          "foreground": "#1e1e2e",
          "leading_diamond": "\ue0b6",
          "options": {
            "style": "roundrock",
            "threshold": 0
          },
          "style": "diamond",
          "template": " \ueba2 {{ .FormattedMs }} ",
          "type": "executiontime"
        },
        {
          "background": "#313244",
          "foreground": "#a6e3a1",
          "leading_diamond": "\ue0b2",
          "options": {
            "fetch_package_manager": true,
            "npm_icon": " <#f38ba8>\ue5fa</> ",
            "yarn_icon": " <#89b4fa>\ue6a7</>"
          },
          "style": "diamond",
          "template": "\ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}",
          "type": "node"
        },
        {
          "background": "#313244",
          "foreground": "#89b4fa",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }}",
          "type": "python"
        },
        {
          "background": "#313244",
          "foreground": "#74c7ec",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue738 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "java"
        },
        {
          "background": "#313244",
          "foreground": "#89b4fa",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue77f {{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }}",
          "type": "dotnet"
        },
        {
          "background": "#313244",
          "foreground": "#89dceb",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue626 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "go"
        },
        {
          "background": "#313244",
          "foreground": "#fab387",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue7a8 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "rust"
        },
        {
          "background": "#313244",
          "foreground": "#74c7ec",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue798 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "dart"
        },
        {
          "background": "#313244",
          "foreground": "#f38ba8",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue753 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "angular"
        },
        {
          "background": "#313244",
          "foreground": "#f5c2e7",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\u03b1 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "aurelia"
        },
        {
          "background": "#181825",
          "foreground": "#cdd6f4",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "{{ if .Error }}{{ .Error }}{{ else }}Nx {{ .Full }}{{ end }}",
          "type": "nx"
        },
        {
          "background": "#313244",
          "foreground": "#a6e3a1",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "<#f38ba8>\ue624</> {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "julia"
        },
        {
          "background": "#313244",
          "foreground": "#eba0ac",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue791 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "ruby"
        },
        {
          "background": "#313244",
          "foreground": "#89b4fa",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\uf104<#f9e2af>\uf0e7</>\uf105 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "azfunc"
        },
        {
          "background": "#45475a",
          "foreground": "#fab387",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue7ad {{.Profile}}{{if .Region}}@{{.Region}}{{end}}",
          "type": "aws"
        },
        {
          "background": "#89b4fa",
          "foreground": "#1e1e2e",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\uf308 {{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}}",
          "type": "kubectl"
        },
        {
          "background": "#585b70",
          "foreground": "#cdd6f4",
          "leading_diamond": "\ue0b2",
          "options": {
            "linux": "\ue712",
            "macos": "\ue711",
            "windows": "\ue70f"
          },
          "style": "diamond",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "type": "os"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#94e2d5",
          "style": "plain",
          "template": "\u2570\u2500",
          "type": "text"
        },
        {
          "foreground": "#cdd6f4",
          "foreground_templates": ["{{ if gt .Code 0 }}#f38ba8{{ end }}"],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\ue285\ueab6 ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#94e2d5",
    "template": "\u2570\u2500<#cdd6f4>\ue285\ueab6 </>"
  },
  "version": 4
}
