{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#e78284",
          "foreground": "#303446",
          "leading_diamond": "\u256d\u2500\ue0b6",
          "style": "diamond",
          "template": "<parentBackground>\ue0b0</> \uf292 ",
          "type": "root"
        },
        {
          "background": "#ef9f76",
          "foreground": "#303446",
          "leading_diamond": "\u256d\u2500\ue0b6",
          "powerline_symbol": "\ue0b0",
          "options": {
            "folder_separator_icon": " \ue0b1 ",
            "home_icon": "\ue617",
            "mixed_threshold": 6,
            "style": "mixed"
          },
          "style": "powerline",
          "template": " \uf07b {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#e5c890",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#eebebe{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#ca9ee6{{ end }}",
            "{{ if gt .Ahead 0 }}#babbf1{{ end }}",
            "{{ if gt .Behind 0 }}#babbf1{{ end }}"
          ],
          "foreground": "#303446",
          "powerline_symbol": "\ue0b0",
          "options": {
            "branch_icon": "\ue725 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "powerline",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#e78284> \uf046 {{ .Staging.String }}</>{{ end }} ",
          "trailing_diamond": "\ue0b0",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "#ca9ee6",
          "foreground": "#303446",
          "leading_diamond": "\ue0b6",
          "options": {
            "style": "roundrock",
            "threshold": 0
          },
          "style": "diamond",
          "template": " \ueba2 {{ .FormattedMs }} ",
          "type": "executiontime"
        },
        {
          "background": "#414559",
          "foreground": "#a6d189",
          "leading_diamond": "\ue0b2",
          "options": {
            "fetch_package_manager": true,
            "npm_icon": " <#e78284>\ue5fa</> ",
            "yarn_icon": " <#8caaee>\ue6a7</>"
          },
          "style": "diamond",
          "template": "\ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}",
          "type": "node"
        },
        {
          "background": "#414559",
          "foreground": "#8caaee",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }}",
          "type": "python"
        },
        {
          "background": "#414559",
          "foreground": "#85c1dc",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue738 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "java"
        },
        {
          "background": "#414559",
          "foreground": "#8caaee",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue77f {{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }}",
          "type": "dotnet"
        },
        {
          "background": "#414559",
          "foreground": "#99d1db",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue626 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "go"
        },
        {
          "background": "#414559",
          "foreground": "#ef9f76",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue7a8 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "rust"
        },
        {
          "background": "#414559",
          "foreground": "#85c1dc",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue798 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "dart"
        },
        {
          "background": "#414559",
          "foreground": "#e78284",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue753 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "angular"
        },
        {
          "background": "#414559",
          "foreground": "#f4b8e4",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\u03b1 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "aurelia"
        },
        {
          "background": "#292c3c",
          "foreground": "#c6d0f5",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "{{ if .Error }}{{ .Error }}{{ else }}Nx {{ .Full }}{{ end }}",
          "type": "nx"
        },
        {
          "background": "#414559",
          "foreground": "#a6d189",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "<#e78284>\ue624</> {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "julia"
        },
        {
          "background": "#414559",
          "foreground": "#ea999c",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue791 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "ruby"
        },
        {
          "background": "#414559",
          "foreground": "#8caaee",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\uf104<#e5c890>\uf0e7</>\uf105 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
          "type": "azfunc"
        },
        {
          "background": "#51576d",
          "foreground": "#ef9f76",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue7ad {{.Profile}}{{if .Region}}@{{.Region}}{{end}}",
          "type": "aws"
        },
        {
          "background": "#8caaee",
          "foreground": "#303446",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\uf308 {{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}}",
          "type": "kubectl"
        },
        {
          "background": "#626880",
          "foreground": "#c6d0f5",
          "leading_diamond": "\ue0b2",
          "options": {
            "linux": "\ue712",
            "macos": "\ue711",
            "windows": "\ue70f"
          },
          "style": "diamond",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "type": "os"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#c6d0f5",
          "foreground_templates": ["{{ if gt .Code 0 }}#e78284{{ end }}"],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\ueab6",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#81c8be",
    "template": "\u2570\u2500<#c6d0f5>\ue285\ueab6 </>"
  },
  "version": 4
}
